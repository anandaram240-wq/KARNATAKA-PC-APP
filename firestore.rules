rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'anandakiccha240@gmail.com';
    }

    // ── ksp_visitors: ANYONE can write (guest + Google), only admin reads ─────
    match /ksp_visitors/{visitorId} {
      allow read: if isAdmin();
      allow create, update: if true;   // guests & logged-in users both track
    }

    // ── ksp_users: any auth user writes own doc, admin reads all ─────────────
    match /ksp_users/{userId} {
      allow read: if request.auth != null && (
        request.auth.token.email == resource.data.email ||
        isAdmin()
      );
      allow create: if request.auth != null && request.auth.token.email == request.resource.data.email;
      allow update: if request.auth != null && (
        request.auth.token.email == resource.data.email ||
        isAdmin()
      );
      
      match /answered/{qid} {
        allow read, write: if request.auth != null && (
          request.auth.token.email == get(/databases/$(database)/documents/ksp_users/$(userId)).data.email ||
          isAdmin()
        );
      }
      
      match /tests/{testId} {
        allow read, write: if request.auth != null && (
          request.auth.token.email == get(/databases/$(database)/documents/ksp_users/$(userId)).data.email ||
          isAdmin()
        );
      }
    }

    // ── ksp_stats (global counters): anyone can increment, admin reads ────────
    match /ksp_stats/{docId} {
      allow read: if isAdmin();
      allow write: if true;
    }

    // ── Legacy /users/ collection ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (resource != null && request.auth.token.email == resource.data.email) ||
        isAdmin()
      );
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        (resource == null && request.auth.token.email == request.resource.data.email) ||
        (resource != null && request.auth.token.email == resource.data.email)
      );
    }

    // ── Visitors: written by trackVisit(), admin reads all ───────────────────
    match /visitors/{docId} {
      allow read: if isAdmin();
      allow create, update: if true;
    }

    // ── Admin stats (global counters) ─────────────────────────────────────────
    match /admin_stats/{docId} {
      allow read: if isAdmin();
      allow write: if true;
    }

    // ── Broadcasts: admin writes, any authenticated user reads ────────────────
    match /broadcasts/{docId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin();
    }

    // ── Admin logs: admin only ────────────────────────────────────────────────
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // ── Leaderboard ───────────────────────────────────────────────────────────
    match /leaderboard/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
